{
    "name": "jetstrike/conflict-detector",
    "description": "Intelligent Plugin Conflict Detector for WordPress and WooCommerce",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "Jetstrike\\ConflictDetector\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jetstrike\\ConflictDetector\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
